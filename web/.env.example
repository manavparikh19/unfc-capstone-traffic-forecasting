# Public base URL used for metadata, sitemap, and share previews.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Enables analytics hook points without requiring a provider in local development.
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Optional webhook destination for demo/contact requests.
CONTACT_WEBHOOK_URL=

# Optional Sentry DSN or other error tracking DSN.
SENTRY_DSN=

# Route provider selection. "demo" uses local structured data and mocked scoring logic.
ROUTE_PROVIDER=demo

# Token placeholder for a future external routing provider integration.
ROUTE_PROVIDER_TOKEN=

# Per-window request caps for the in-memory rate limiter.
CONTACT_RATE_LIMIT_MAX=6
ROUTE_PLAN_RATE_LIMIT_MAX=20
