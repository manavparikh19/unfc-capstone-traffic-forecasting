# Public base URL used for metadata, sitemap, and share previews.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Enables analytics hook points without requiring a provider in local development.
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# When true, frontend data hooks use local mock payloads instead of /api endpoints.
NEXT_PUBLIC_USE_MOCK_DATA=false

# When true, API failures can fall back to demo payloads (recommended false for production).
NEXT_PUBLIC_ALLOW_FALLBACK_ON_ERROR=false

# Optional webhook destination for demo/contact requests.
CONTACT_WEBHOOK_URL=

# Optional Sentry DSN or other error tracking DSN.
SENTRY_DSN=

# Route provider selection. "demo" uses local structured data and mocked scoring logic.
ROUTE_PROVIDER=demo

# Token placeholder for a future external routing provider integration.
ROUTE_PROVIDER_TOKEN=

# Optional FastAPI model-serving backend URL (for live inference).
MODEL_SERVICE_URL=http://127.0.0.1:8000

# Timeout for model service calls in milliseconds.
MODEL_SERVICE_TIMEOUT_MS=30000

# Default location identifier used by forecast proxy when none is supplied.
FORECAST_DEFAULT_LOCATION_ID=10133019_NB

# Per-window request caps for the in-memory rate limiter.
CONTACT_RATE_LIMIT_MAX=6
ROUTE_PLAN_RATE_LIMIT_MAX=20